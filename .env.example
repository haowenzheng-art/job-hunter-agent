# ==================== 火山引擎 API 配置 ====================
# ==================== 数据库配置 ====================
# v2.1 M5+: 默认 PostgreSQL+pgvector（docker compose up -d postgres）
DATABASE_URL=postgresql://jobhunter:jobhunter@localhost:5432/jobhunter
# 回退 SQLite（本地无 docker 时）：
# DATABASE_URL=sqlite:///data/jobhunter_v2.db

# ==================== Embedding / 多模态 / 上下文生成 ====================
EMBEDDING_MODEL=text-embedding-3-small  # 可替换为兼容接口，如 bge-m3、text2vec
MULTIMODAL_MODEL=gpt-4o  # 可替换为兼容接口，如 claude-sonnet-4-20250514、qwen-vl-max
CONTEXTUALIZER_MODEL=gpt-4o-mini  # 可替换为兼容接口，用于 chunk context 生成

VOLCANO_API_KEY=your_api_key_here
VOLCANO_CODING_API_URL=https://apihub.agnes-ai.com/v1
VOLCANO_CHAT_API_URL=https://apihub.agnes-ai.com/v1
VOLCANO_MODEL=agnes-2.0-flash
VOLCANO_USE_CODING_API=true

# ==================== Anthropic API 配置 ====================
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
MAX_TOKENS=4096

# ==================== 招聘平台配置 ====================
# Boss直聘
BOSS_COOKIES_FILE=data/cookies/boss.json
BOSS_LOGIN_URL=https://login.zhipin.com

# 猎聘
LIEPIN_COOKIES_FILE=data/cookies/liepin.json
LIEPIN_LOGIN_URL=https://www.liepin.com

# JobsDB
JOBSDB_COOKIES_FILE=data/cookies/jobsdb.json
JOBSDB_LOGIN_URL=https://hk.jobsdb.com

# ==================== 爬虫配置 ====================
# 反爬：请求延迟（秒）
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0

# 反爬：并发限制
MAX_CONCURRENT_JOBS=10

# 反爬：浏览器配置
HEADLESS_BROWSER=true
BROWSER_PROFILE_DIR=data/browser_profiles

# ==================== 爬虫策略配置 ====================
# 爬取间隔（秒），每次请求之间的随机等待
CRAWLER_RATE_LIMIT_MIN=2.0
CRAWLER_RATE_LIMIT_MAX=5.0
# 每日爬取上限（JD 条数）
CRAWLER_DAILY_LIMIT=200
# 被封禁（403/429）后的暂停时间（分钟）
CRAWLER_BLOCKED_TIMEOUT_MIN=30
# 单次请求最大重试次数
CRAWLER_MAX_RETRIES=3
# 单次请求超时（秒）
CRAWLER_TIMEOUT=30
# 同一时间最多并发爬取的域名数
CRAWLER_CONCURRENT_DOMAINS=3

# ==================== Edge 复用配置 ====================
# 自定义 Edge User Data 路径（留空则自动检测 %LOCALAPPDATA%\Microsoft\Edge\User Data）
CRAWLER_EDGE_USER_DATA=
# Edge 配置文件名（通常为 Default）
CRAWLER_EDGE_PROFILE=Default

# ==================== 缓存配置 ====================
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_DIR=data/cache

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=job_hunter.log

# ==================== 投递配置 ====================
# 自动投递阈值（匹配度百分比）
AUTO_APPLY_THRESHOLD=85

# 手动确认阈值
MANUAL_CONFIRM_MIN=70

# ==================== 性能配置 ====================
# LLM 并发数
LLM_CONCURRENCY=5

# 上下文最大 Token 数
MAX_CONTEXT_TOKENS=100000

# 上下文压缩阈值
CONTEXT_COMPRESS_THRESHOLD=80000